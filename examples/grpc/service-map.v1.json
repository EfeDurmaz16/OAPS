{
  "package": "oaps.bindings.grpc.v1",
  "services": [
    {
      "service": "DiscoveryService",
      "methods": [
        {
          "name": "GetWellKnown",
          "mode": "unary"
        },
        {
          "name": "GetActorCard",
          "mode": "unary"
        },
        {
          "name": "ListCapabilities",
          "mode": "unary"
        }
      ]
    },
    {
      "service": "InteractionsService",
      "methods": [
        {
          "name": "CreateInteraction",
          "mode": "unary"
        },
        {
          "name": "GetInteraction",
          "mode": "unary"
        },
        {
          "name": "AppendMessage",
          "mode": "unary"
        },
        {
          "name": "ApproveInteraction",
          "mode": "unary"
        },
        {
          "name": "RejectInteraction",
          "mode": "unary"
        },
        {
          "name": "RevokeInteraction",
          "mode": "unary"
        }
      ]
    },
    {
      "service": "ReplayService",
      "methods": [
        {
          "name": "ListEvents",
          "mode": "unary"
        },
        {
          "name": "ListEvidence",
          "mode": "unary"
        },
        {
          "name": "WatchEvents",
          "mode": "server_streaming"
        },
        {
          "name": "WatchEvidence",
          "mode": "server_streaming"
        }
      ]
    }
  ]
}
