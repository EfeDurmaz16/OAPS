{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oaps.dev/conformance/results/compatibility-declaration-schema.v1.json",
  "title": "OAPS Compatibility Declaration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "declaration_schema_version",
    "manifest_id",
    "suite_version",
    "generated_at",
    "source_result",
    "implementation",
    "selected_scopes",
    "summary",
    "scope_declarations",
    "issues"
  ],
  "properties": {
    "declaration_schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "suite_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_path",
        "runner_id",
        "executed_at"
      ],
      "properties": {
        "result_path": {
          "type": "string",
          "minLength": 1
        },
        "runner_id": {
          "type": "string"
        },
        "executed_at": {
          "type": "string"
        }
      }
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "implementation_id",
        "implementation_version"
      ],
      "properties": {
        "implementation_id": {
          "type": "string",
          "minLength": 1
        },
        "implementation_version": {
          "type": "string",
          "minLength": 1
        },
        "metadata": {
          "type": "object"
        }
      }
    },
    "selected_scopes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "compatible",
        "partial",
        "incompatible",
        "not_evaluated",
        "total"
      ],
      "properties": {
        "compatible": {
          "type": "integer",
          "minimum": 0
        },
        "partial": {
          "type": "integer",
          "minimum": 0
        },
        "incompatible": {
          "type": "integer",
          "minimum": 0
        },
        "not_evaluated": {
          "type": "integer",
          "minimum": 0
        },
        "total": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "scope_declarations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scope",
          "status",
          "selected_in_result",
          "known_scenarios",
          "evaluated_scenarios",
          "pass",
          "fail",
          "skip",
          "error",
          "coverage_observed",
          "known_scenario_ids",
          "evaluated_scenario_ids"
        ],
        "properties": {
          "scope": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "compatible",
              "partial",
              "incompatible",
              "not_evaluated"
            ]
          },
          "selected_in_result": {
            "type": "boolean"
          },
          "known_scenarios": {
            "type": "integer",
            "minimum": 0
          },
          "evaluated_scenarios": {
            "type": "integer",
            "minimum": 0
          },
          "pass": {
            "type": "integer",
            "minimum": 0
          },
          "fail": {
            "type": "integer",
            "minimum": 0
          },
          "skip": {
            "type": "integer",
            "minimum": 0
          },
          "error": {
            "type": "integer",
            "minimum": 0
          },
          "coverage_observed": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "known_scenario_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "evaluated_scenario_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "message"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
