{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oaps.dev/conformance/results/result-schema.v1.json",
  "title": "OAPS Conformance Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "result_schema_version",
    "manifest_id",
    "runner_id",
    "implementation",
    "executed_at",
    "scopes",
    "summary",
    "scenarios"
  ],
  "properties": {
    "result_schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "runner_id": {
      "type": "string",
      "minLength": 1
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "implementation_id",
        "implementation_version"
      ],
      "properties": {
        "implementation_id": {
          "type": "string",
          "minLength": 1
        },
        "implementation_version": {
          "type": "string",
          "minLength": 1
        },
        "metadata": {
          "type": "object"
        }
      }
    },
    "executed_at": {
      "type": "string",
      "format": "date-time"
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pass",
        "fail",
        "skip",
        "error",
        "total"
      ],
      "properties": {
        "pass": {
          "type": "integer",
          "minimum": 0
        },
        "fail": {
          "type": "integer",
          "minimum": 0
        },
        "skip": {
          "type": "integer",
          "minimum": 0
        },
        "error": {
          "type": "integer",
          "minimum": 0
        },
        "total": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scenario_id",
          "scope",
          "outcome",
          "coverage"
        ],
        "properties": {
          "scenario_id": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "string",
            "minLength": 1
          },
          "outcome": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "skip",
              "error"
            ]
          },
          "coverage": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "duration_ms": {
            "type": "integer",
            "minimum": 0
          },
          "notes": {
            "type": "string"
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
