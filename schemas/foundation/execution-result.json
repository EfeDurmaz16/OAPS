{
  "$id": "https://oaps.dev/schemas/foundation/execution-result.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OAPS Foundation ExecutionResult",
  "type": "object",
  "required": [
    "execution_id",
    "status",
    "timestamp"
  ],
  "properties": {
    "execution_id": {
      "type": "string"
    },
    "status": {
      "$ref": "foundation/common.json#/$defs/executionStatus"
    },
    "result": {
      "type": "object"
    },
    "task_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
