{
  "$id": "https://oaps.dev/schemas/foundation/capability.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OAPS Foundation Capability",
  "type": "object",
  "required": [
    "capability_id",
    "kind",
    "name",
    "risk_class"
  ],
  "properties": {
    "capability_id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "tool",
        "task",
        "service",
        "workflow",
        "payment",
        "approval",
        "message",
        "other"
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "input_schema": {
      "type": "object"
    },
    "output_schema": {
      "type": "object"
    },
    "risk_class": {
      "$ref": "foundation/common.json#/$defs/riskClass"
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
