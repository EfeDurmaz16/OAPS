{
  "$id": "https://oaps.dev/schemas/delegation-token.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OAPS DelegationToken",
  "type": "object",
  "required": [
    "delegation_id",
    "delegator",
    "delegatee",
    "scope",
    "expires_at"
  ],
  "properties": {
    "delegation_id": {
      "type": "string"
    },
    "delegator": {
      "$ref": "common.json#/$defs/actorRef"
    },
    "delegatee": {
      "$ref": "common.json#/$defs/actorRef"
    },
    "scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "verb",
          "target"
        ],
        "properties": {
          "verb": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "conditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "limits": {
      "type": "object",
      "properties": {
        "max_amount": {
          "$ref": "common.json#/$defs/money"
        },
        "max_daily_spend": {
          "$ref": "common.json#/$defs/money"
        },
        "max_executions": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "approval_policy_id": {
      "type": "string"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "revocation_endpoint": {
      "type": "string",
      "format": "uri"
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}