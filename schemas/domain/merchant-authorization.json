{
  "$id": "https://oaps.dev/schemas/domain/merchant-authorization.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OAPS Draft Merchant Authorization",
  "type": "object",
  "required": [
    "merchant_authorization_id",
    "merchant",
    "order_intent_id",
    "decision"
  ],
  "properties": {
    "merchant_authorization_id": {
      "type": "string"
    },
    "merchant": {
      "$ref": "../foundation/common.json#/$defs/actorRef"
    },
    "order_intent_id": {
      "type": "string"
    },
    "decision": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "decided_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
