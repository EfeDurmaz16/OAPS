{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "paths": {
      "@oaps/core": ["packages/core/src/index.ts"],
      "@oaps/evidence": ["packages/evidence/src/index.ts"],
      "@oaps/policy": ["packages/policy/src/index.ts"],
      "@oaps/mcp-adapter": ["packages/mcp-adapter/src/index.ts"],
      "@oaps/http": ["packages/http/src/index.ts"]
    }
  }
}
